rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isFounder() {
      return request.auth != null
        && request.auth.token.email in [
          'mivermedina7@gmail.com',
          'williamir1234@gmail.com'
        ];
    }

    function isListedAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    function isAdmin() {
      return isFounder() || isListedAdmin();
    }

    match /admins/{adminEmail} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'email',
          'role',
          'addedBy',
          'addedAt',
          'creadoEn'
        ])
        && request.resource.data.email is string
        && request.resource.data.email == adminEmail
        && request.resource.data.role in ['editor', 'founder']
        && request.resource.data.addedBy is string
        && request.resource.data.addedAt is string;
      allow update: if isFounder()
        && request.resource.data.keys().hasOnly([
          'email',
          'role',
          'addedBy',
          'addedAt',
          'creadoEn'
        ])
        && request.resource.data.role in ['editor', 'founder'];
      allow delete: if isAdmin();
    }

    match /pedidos_camisetas/{pedidoId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
          'nombre',
          'numero',
          'talla',
          'genero',
          'fecha'
        ])
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() >= 2
        && request.resource.data.nombre.size() <= 80
        && request.resource.data.numero is number
        && request.resource.data.numero >= 1
        && request.resource.data.numero <= 99
        && request.resource.data.talla is string
        && request.resource.data.genero in ['hombre', 'mujer'];
      allow update, delete: if isAdmin();
    }

    match /recuerdos_promocion/{recuerdoId} {
      allow read: if resource.data.estado in ['aprobado', 'destacado'] || isAdmin();
      allow create: if request.resource.data.keys().hasOnly([
          'nombre',
          'promocion',
          'mensaje',
          'imagenUrl',
          'imagenPublicId',
          'estado',
          'fecha'
        ])
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() >= 2
        && request.resource.data.nombre.size() <= 80
        && request.resource.data.promocion == '2025'
        && request.resource.data.mensaje is string
        && request.resource.data.mensaje.size() >= 5
        && request.resource.data.mensaje.size() <= 900
        && request.resource.data.estado == 'pendiente';
      allow update, delete: if isAdmin();
    }

    match /comentarios_recuerdos/{comentarioId} {
      allow read: if resource.data.estado in ['publicado', 'aprobado'] || isAdmin();
      allow create: if request.resource.data.keys().hasOnly([
          'recuerdoId',
          'parentId',
          'nombre',
          'mensaje',
          'estado',
          'censurado',
          'fecha'
        ])
        && request.resource.data.recuerdoId is string
        && request.resource.data.parentId is string
        && request.resource.data.parentId.size() <= 120
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() >= 2
        && request.resource.data.nombre.size() <= 80
        && request.resource.data.mensaje is string
        && request.resource.data.mensaje.size() >= 3
        && request.resource.data.mensaje.size() <= 280
        && request.resource.data.censurado is bool
        && request.resource.data.estado == 'publicado';
      allow update, delete: if isAdmin();
    }

    match /partidos_reencuentro/{partidoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /inscripciones_deportivas/{inscripcionId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
          'nombre',
          'disciplinas',
          'promocion',
          'fecha'
        ])
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() >= 2
        && request.resource.data.nombre.size() <= 80
        && request.resource.data.disciplinas is list
        && request.resource.data.disciplinas.size() >= 1
        && request.resource.data.disciplinas.size() <= 5
        && request.resource.data.disciplinas.hasOnly([
          'voley-mixto',
          'voley-femenino',
          'basket-mujer',
          'basket-varones',
          'futbol'
        ])
        && request.resource.data.promocion == '2025';
      allow update, delete: if isAdmin();
    }

    match /agenda_reencuentro/{agendaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
